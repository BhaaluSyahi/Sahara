# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/volunteer_matching

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name
# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SENDER_EMAIL=youremail@gmail.com
SMTP_PASSWORD=your-app-password

# Agent URLs
DOC_EXTRACTION_AGENT_URL=http://localhost:8001/extract
REQUEST_RESEARCH_AGENT_URL=http://localhost:8002/research

# App
DEBUG=True
